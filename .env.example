# =============================================================================
# CPI Dashboard — environment variables
# =============================================================================
# Copy this file to `.env` and fill in real values for LOCAL runs:
#
#     cp .env.example .env
#
# `.env` is gitignored and must never be committed. In production these same
# variables are set as GitHub Actions secrets (see .github/workflows/refresh.yml).
#
# The dummy-data path (`python scripts/run_pipeline.py --dummy-data --dry-run`)
# needs NONE of these — it runs entirely on generated fixtures.
# -----------------------------------------------------------------------------

# --- GA4 (Google Analytics Data API) ---------------------------------------
# Numeric GA4 property IDs (the number, not "properties/...").
GA4_PROPERTY_CPI=
GA4_PROPERTY_WELLSPRING=
# Auth is Application Default Credentials (ADC), NOT a service account. Set it up
# once on the machine that runs the pipeline:
#   gcloud auth application-default login \
#     --scopes=https://www.googleapis.com/auth/analytics.readonly,https://www.googleapis.com/auth/cloud-platform
#   gcloud auth application-default set-quota-project fillungo-reporting
# Leave GOOGLE_APPLICATION_CREDENTIALS unset so Python finds the ADC file
# (~/.config/gcloud/application_default_credentials.json) automatically.
# GOOGLE_APPLICATION_CREDENTIALS=

# --- Google Ads API ----------------------------------------------------------
# Customer ID of the account to query, digits only (no dashes).
GADS_CUSTOMER_ID=
GADS_DEVELOPER_TOKEN=
GADS_REFRESH_TOKEN=
# These three are required by the Google Ads client but are NOT yet in the
# GitHub Actions workflow — add them as secrets there before the first live run.
GADS_CLIENT_ID=
GADS_CLIENT_SECRET=
GADS_LOGIN_CUSTOMER_ID=

# --- Google Sheets (performance_summary, source of truth for new patients) ---
# Service-account JSON (single-line string). May be the same SA as GA4 if it
# has access to the sheet. Share the sheet with the service-account email.
GSHEETS_SA_JSON=
# The sheet ID from its URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
PERFORMANCE_SUMMARY_SHEET_ID=

# --- Slack -------------------------------------------------------------------
# Incoming-webhook URL for #cpi-health.
SLACK_CPI_WEBHOOK=

# --- GitHub Pages deploy (LOCAL runs only) -----------------------------------
# Personal access token with `contents: write` on the repo. In GitHub Actions
# the built-in GITHUB_TOKEN is used instead, so this is only for local deploys.
GITHUB_DEPLOY_TOKEN=
