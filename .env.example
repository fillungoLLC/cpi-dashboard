# =============================================================================
# CPI Dashboard — environment variables
# =============================================================================
# Copy this file to `.env` and fill in real values for LOCAL runs:
#
#     cp .env.example .env
#
# `.env` is gitignored. In production these same variables are set as GitHub
# Actions secrets (see .github/workflows/refresh.yml).
#
# The dummy-data path (`python scripts/run_pipeline.py --dummy-data --dry-run`)
# needs NONE of these.
# -----------------------------------------------------------------------------

# === PRODUCTION PATH (required) ==============================================
# Production ingestion runs in Apps Script + a Google Ads-bound script, both of
# which write to a single staging Google Sheet. Python reads the Sheet via
# gspread. These two vars are the only ones the prod pipeline needs.

STAGING_SHEET_ID=
# Service-account JSON (single-line string). The service account only needs
# Viewer access on the staging Sheet itself — not on GA4 or Google Ads.
# Locally you can leave this unset; gspread will fall back to default auth (ADC).
GSHEETS_SA_JSON=

# Slack incoming-webhook for #cpi-health.
SLACK_CPI_WEBHOOK=

# === LEGACY / LOCAL FALLBACK (only needed for --legacy-direct runs) ==========
# These bypass the staging Sheet and pull GA4, Google Ads, and Justin's CSV
# directly from each API. Local-only — headless CI cannot use ADC for GA4 and
# we don't need the Google Ads developer token in production anymore.

# --- GA4 (legacy direct path) ------------------------------------------------
# GA4_PROPERTY_CPI=
# GA4_PROPERTY_WELLSPRING=
# Auth: ADC. One-time setup:
#   gcloud auth application-default login \
#     --scopes=https://www.googleapis.com/auth/analytics.readonly,https://www.googleapis.com/auth/cloud-platform
#   gcloud auth application-default set-quota-project fillungo-reporting
# Leave GOOGLE_APPLICATION_CREDENTIALS unset; Python will find the ADC file.

# --- Google Ads (legacy direct path) -----------------------------------------
# GADS_CUSTOMER_ID=
# GADS_DEVELOPER_TOKEN=
# GADS_REFRESH_TOKEN=
# GADS_CLIENT_ID=
# GADS_CLIENT_SECRET=
# GADS_LOGIN_CUSTOMER_ID=

# --- Justin's CSV (legacy direct path) ---------------------------------------
# PERFORMANCE_SUMMARY_SHEET_ID=

# === GitHub Pages deploy (LOCAL runs only) ===================================
# Personal access token with `contents: write` on the repo. In GitHub Actions
# the built-in GITHUB_TOKEN is used instead, so this is only for local deploys.
GITHUB_DEPLOY_TOKEN=
